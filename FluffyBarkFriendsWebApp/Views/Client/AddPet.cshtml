@model FluffyBarkFriendsWebApp.Models.Database.Pet

@{
    ViewData["Title"] = "Add Pet";
}

<section class="page-panel">

    <div class="page-header">
        <p class="eyebrow">Client Portal</p>
        <h1>Add Pet</h1>
        <p class="page-description">
            Register your pet information.
        </p>
    </div>

    <form asp-action="AddPet" method="post">

        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="row">

            <div class="col-md-6 mb-3">
                <label asp-for="PetName" class="form-label">Pet Name</label>
                <input asp-for="PetName" class="form-control" placeholder="Enter pet name" />
                <span asp-validation-for="PetName" class="text-danger"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="Species" class="form-label">Species</label>
                <input asp-for="Species" class="form-control" placeholder="Dog, Cat, etc." />
                <span asp-validation-for="Species" class="text-danger"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="Breed" class="form-label">Breed</label>
                <input asp-for="Breed" class="form-control" placeholder="Enter breed" />
                <span asp-validation-for="Breed" class="text-danger"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="Sex" class="form-label">Sex</label>
                <select asp-for="Sex" class="form-select">
                    <option value="">Select sex</option>
                    <option value="Male">Male</option>
                    <option value="Female">Female</option>
                </select>
                <span asp-validation-for="Sex" class="text-danger"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="BirthDate" class="form-label">Birth Date</label>
                <input asp-for="BirthDate" type="date" class="form-control" />
                <span asp-validation-for="BirthDate" class="text-danger"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="AgeYears" class="form-label">Age</label>
                <input asp-for="AgeYears" type="number" class="form-control" placeholder="Enter age" />
                <span asp-validation-for="AgeYears" class="text-danger"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="Color" class="form-label">Color</label>
                <input asp-for="Color" class="form-control" placeholder="Enter color" />
                <span asp-validation-for="Color" class="text-danger"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="Weight" class="form-label">Weight</label>
                <input asp-for="Weight" type="number" step="0.01" class="form-control" placeholder="Enter weight" />
                <span asp-validation-for="Weight" class="text-danger"></span>
            </div>

            <div class="col-md-12 mb-4">
                <label asp-for="Notes" class="form-label">Notes</label>
                <textarea asp-for="Notes" class="form-control" rows="4" placeholder="Optional notes"></textarea>
                <span asp-validation-for="Notes" class="text-danger"></span>
            </div>

        </div>

        <button type="submit" class="pet-main-btn border-0">
            Save Pet
        </button>

        <a asp-action="MyPet" class="pet-outline-btn">
            Back
        </a>

    </form>

</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}