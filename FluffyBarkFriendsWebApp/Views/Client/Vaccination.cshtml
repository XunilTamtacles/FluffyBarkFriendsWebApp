@model IEnumerable<FluffyBarkFriendsWebApp.Models.Database.Vaccination>

@{
    ViewData["Title"] = "Vaccination";
}

<section class="page-panel">

    <div class="page-header">

        <p class="eyebrow">
            Client Portal
        </p>

        <h1>
            Vaccination Records
        </h1>

        <p class="page-description">
            Monitor your pet vaccination schedules and records.
        </p>

    </div>

    <div class="table-responsive">

        <table class="table custom-table align-middle">

            <thead>

                <tr>
                    <th>Vaccine</th>
                    <th>Date Given</th>
                    <th>Next Due Date</th>
                    <th>Dose</th>
                    <th>Remarks</th>
                </tr>

            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    <tr>

                        <td>
                            @item.VaccineName
                        </td>

                        <td>
                            @item.DateGiven
                        </td>

                        <td>
                            @item.NextDueDate
                        </td>

                        <td>
                            @item.Dose
                        </td>

                        <td>
                            @item.Remarks
                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</section>