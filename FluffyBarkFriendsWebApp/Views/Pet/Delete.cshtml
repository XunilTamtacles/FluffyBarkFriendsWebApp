@model FluffyBarkFriendsWebApp.Models.Database.Pet

@{
    ViewData["Title"] = "Delete Pet";
}

<section class="page-panel">
    <span class="eyebrow">Pet Management</span>
    <h1>Delete Pet</h1>
    <p>Confirm if you want to remove this pet profile.</p>
</section>

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-4">
        <p class="text-danger fw-semibold">
            Are you sure you want to delete this pet record?
        </p>

        <dl class="row">
            <dt class="col-sm-3">Pet Name</dt>
            <dd class="col-sm-9">@Model.PetName</dd>

            <dt class="col-sm-3">Species</dt>
            <dd class="col-sm-9">@Model.Species</dd>

            <dt class="col-sm-3">Breed</dt>
            <dd class="col-sm-9">@Model.Breed</dd>

            <dt class="col-sm-3">Sex</dt>
            <dd class="col-sm-9">@Model.Sex</dd>

            <dt class="col-sm-3">Age</dt>
            <dd class="col-sm-9">@Model.AgeYears</dd>

            <dt class="col-sm-3">Color</dt>
            <dd class="col-sm-9">@Model.Color</dd>

            <dt class="col-sm-3">Weight</dt>
            <dd class="col-sm-9">@Model.Weight</dd>
        </dl>

        <form asp-action="Delete" method="post">
            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="PetId" />

            <button type="submit" class="btn btn-danger rounded-pill px-4">
                Delete
            </button>

            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
                Cancel
            </a>
        </form>
    </div>
</div>