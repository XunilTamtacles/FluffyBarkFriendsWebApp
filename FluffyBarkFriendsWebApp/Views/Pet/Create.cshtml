@using FluffyBarkFriendsWebApp.Models.ViewModels
@model PetFormsViewModel

@{
    ViewData["Title"] = "Create Pet";
}

<section class="page-panel">
    <span class="eyebrow">Pet Management</span>
    <h1>Register Pet</h1>
    <p>Add a new pet profile into the clinic system.</p>
</section>

<div class="pet-form-card">
    <form asp-action="Create" method="post">

        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly"
             class="text-danger mb-3">
        </div>

        <partial name="_Form" model="Model" />

        <div class="pet-form-actions">
            <button type="submit" class="btn btn-success">
                Save Pet
            </button>

            <a asp-action="Index" class="btn btn-outline-secondary">
                Back
            </a>
        </div>

    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}