@model FluffyBarkFriendsWebApp.Models.ViewModels.PetFormsViewModel

<div class="row g-3">

    <div class="col-md-6">
        <label asp-for="PetName" class="form-label"></label>

        <input asp-for="PetName"
               class="form-control"
               placeholder="Enter pet name" />

        <span asp-validation-for="PetName"
              class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="Species" class="form-label"></label>

        <input asp-for="Species"
               class="form-control"
               placeholder="Dog, Cat, Bird..." />

        <span asp-validation-for="Species"
              class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="Breed" class="form-label"></label>

        <input asp-for="Breed"
               class="form-control"
               placeholder="Golden Retriever..." />

        <span asp-validation-for="Breed"
              class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="Sex" class="form-label"></label>

        <select asp-for="Sex"
                class="form-control">

            <option value="">Select Sex</option>
            <option value="Male">Male</option>
            <option value="Female">Female</option>

        </select>

        <span asp-validation-for="Sex"
              class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="BirthDate"
               class="form-label"></label>

        <input asp-for="BirthDate"
               type="date"
               class="form-control" />

        <span asp-validation-for="BirthDate"
              class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="AgeYears"
               class="form-label"></label>

        <input asp-for="AgeYears"
               class="form-control"
               placeholder="Enter age" />

        <span asp-validation-for="AgeYears"
              class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="Color"
               class="form-label"></label>

        <input asp-for="Color"
               class="form-control"
               placeholder="Brown, White..." />

        <span asp-validation-for="Color"
              class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="Weight"
               class="form-label"></label>

        <input asp-for="Weight"
               class="form-control"
               placeholder="Weight in kg" />

        <span asp-validation-for="Weight"
              class="text-danger"></span>
    </div>

</div>