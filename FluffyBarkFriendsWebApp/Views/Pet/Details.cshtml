@model FluffyBarkFriendsWebApp.Models.Database.Pet

@{
    ViewData["Title"] = "Pet Details";
}

<section class="page-panel">

    <span class="eyebrow">
        Pet Information
    </span>

    <h1>
        Pet Details
    </h1>

    <p>
        Complete information about this pet.
    </p>

</section>

<div class="card border-0 shadow-sm rounded-4">

    <div class="card-body p-4">

        <div class="d-flex align-items-center gap-4 mb-4">

            <div class="rounded-circle bg-success text-white d-flex align-items-center justify-content-center"
                 style="width:90px;height:90px;font-size:42px;">

                🐾

            </div>

            <div>

                <h2 class="mb-1">
                    @Model.PetName
                </h2>

                <div class="text-muted">
                    @Model.Species • @Model.Breed
                </div>

            </div>

        </div>

        <div class="row g-3">

            <div class="col-md-4">

                <div class="clinic-stat rounded-4 p-3">

                    <span class="text-muted small">
                        Owner
                    </span>

                    <h3 class="h6 mb-0">
                        @Model.OwnerName
                    </h3>

                </div>

            </div>

            <div class="col-md-4">

                <div class="clinic-stat rounded-4 p-3">

                    <span class="text-muted small">
                        Contact
                    </span>

                    <h3 class="h6 mb-0">
                        @Model.ContactNumber
                    </h3>

                </div>

            </div>

            <div class="col-md-4">

                <div class="clinic-stat rounded-4 p-3">

                    <span class="text-muted small">
                        Weight
                    </span>

                    <h3 class="h6 mb-0">
                        @Model.Weight kg
                    </h3>

                </div>

            </div>

        </div>

        <hr />

        <dl class="row">

            <dt class="col-sm-3">Sex</dt>
            <dd class="col-sm-9">@Model.Sex</dd>

            <dt class="col-sm-3">Birth Date</dt>
            <dd class="col-sm-9">@Model.BirthDate</dd>

            <dt class="col-sm-3">Age</dt>
            <dd class="col-sm-9">@Model.AgeYears years old</dd>

            <dt class="col-sm-3">Color</dt>
            <dd class="col-sm-9">@Model.Color</dd>

            <dt class="col-sm-3">Notes</dt>
            <dd class="col-sm-9">@Model.Notes</dd>

        </dl>

        <div class="mt-4 d-flex gap-2">

            <a asp-action="Edit"
               asp-route-id="@Model.PetId"
               class="btn btn-success rounded-pill px-4">

                Edit

            </a>

            <a asp-action="Index"
               class="btn btn-outline-secondary rounded-pill px-4">

                Back

            </a>

        </div>

    </div>

</div>