@{
    ViewData["Title"] = "Home";
}

<section class="pet-landing">

    <div class="pet-landing-content">

        <div class="hero-logo-wrapper">
            <img src="~/images/fluffy-logo.png"
                 alt="Fluffy BarkFriends Logo"
                 class="hero-logo" />
        </div>

        <span class="pet-kicker">
            Veterinary Clinic System
        </span>

        <h1>
            We care about <br />
            your pets
        </h1>

        <p>
            Fluffy BarkFriends helps pet owners easily request appointments online while the clinic efficiently manages pet records, medical history, and vaccination schedules in one centralized veterinary system.
        </p>

        <div class="pet-actions">

            <a asp-controller="Appointment"
               asp-action="Book"
               class="pet-main-btn">
                📅 Book Appointment
            </a>

            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                @if (User.IsInRole("Admin"))
                {
                    <a asp-controller="DashBoard"
                       asp-action="Index"
                       class="pet-outline-btn">
                        📊 Admin Dashboard
                    </a>
                }
                else if (User.IsInRole("Staff"))
                {
                    <a asp-controller="DashBoard"
                       asp-action="Index"
                       class="pet-outline-btn">
                        🩺 Staff Dashboard
                    </a>
                }
                else
                {
                    <a asp-controller="Client"
                       asp-action="Index"
                       class="pet-outline-btn">
                        🐾 My Portal
                    </a>
                }
            }
            else
            {
                <a asp-controller="Account"
                   asp-action="Login"
                   class="pet-outline-btn">
                    🔐 Login
                </a>
            }

        </div>

    </div>

    <div class="pet-landing-visual">

        <div class="pet-photo pet-photo-small">
            <img src="~/images/vet-small.png"
                 alt="Pet Checkup" />
        </div>

        <div class="pet-photo pet-photo-main">
            <img src="~/images/vet-main.png"
                 alt="Veterinary Care" />
        </div>

        <div class="paw-shape">
            🐾
        </div>

    </div>

</section>

<section class="services-panel">

    <div class="services-content">

        <p class="eyebrow">
            Clinic Offers
        </p>

        <h2>
            SERVICES
        </h2>

        <div class="services-grid">

            <ul>
                <li>Laboratory Diagnosis</li>
                <li>Direct Microscopy</li>
                <li>Stool Test</li>
                <li>Microfilarial Test</li>
                <li>Vaginal Smear</li>
                <li>Complete Blood Count (CBC)</li>
            </ul>

            <ul>
                <li>Pet Shop / Accessories</li>
                <li>Veterinary Pharmacy</li>
                <li>Vaccination and Deworming</li>
                <li>Veterinary Consultation</li>
                <li>Grooming Services</li>
            </ul>

        </div>

    </div>

</section>

<section class="home-service-row">

    <div class="home-service-card">
        <div class="service-icon">📅</div>
        <h3>Appointment Booking</h3>
        <p>Clients can request appointments online and receive clinic approval quickly and conveniently.</p>
    </div>

    <div class="home-service-card">
        <div class="service-icon">🐶</div>
        <h3>Pet Management</h3>
        <p>Store and manage pet profiles, owner details, and important veterinary information.</p>
    </div>

    <div class="home-service-card">
        <div class="service-icon">📋</div>
        <h3>Medical History</h3>
        <p>Track pet diagnoses, treatments, medications, and clinic visit history efficiently.</p>
    </div>

    <div class="home-service-card">
        <div class="service-icon">💉</div>
        <h3>Vaccination Tracking</h3>
        <p>Monitor vaccine schedules and upcoming due dates to keep pets safe and healthy.</p>
    </div>

</section>