@model FluffyBarkFriendsWebApp.Models.ViewModels.VaccinationRecordFormsViewModel

<div class="row g-3">
    <div class="col-md-6">
        <label asp-for="PetId" class="form-label"></label>
        <select asp-for="PetId" asp-items="Model.PetOptions" class="form-control">
            <option value="">-- Select Pet --</option>
        </select>
        <span asp-validation-for="PetId" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="AppointmentId" class="form-label"></label>
        <select asp-for="AppointmentId" asp-items="Model.AppointmentOptions" class="form-control">
            <option value="">-- No Appointment --</option>
        </select>
        <span asp-validation-for="AppointmentId" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="VaccineName" class="form-label"></label>
        <input asp-for="VaccineName" class="form-control" placeholder="Example: Anti-rabies, 5-in-1" />
        <span asp-validation-for="VaccineName" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="Dose" class="form-label"></label>
        <input asp-for="Dose" class="form-control" placeholder="Example: 1st dose" />
        <span asp-validation-for="Dose" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="DateGiven" class="form-label"></label>
        <input asp-for="DateGiven" type="date" class="form-control" />
        <span asp-validation-for="DateGiven" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="NextDueDate" class="form-label"></label>
        <input asp-for="NextDueDate" type="date" class="form-control" />
        <span asp-validation-for="NextDueDate" class="text-danger"></span>
    </div>

    <div class="col-12">
        <label asp-for="Remarks" class="form-label"></label>
        <textarea asp-for="Remarks" rows="3" class="form-control" placeholder="Additional remarks"></textarea>
        <span asp-validation-for="Remarks" class="text-danger"></span>
    </div>
</div>