@model FluffyBarkFriendsWebApp.Models.Database.Vaccination

@{
    ViewData["Title"] = "Delete Vaccination";
}

<section class="page-panel">
    <span class="eyebrow">Vaccination Records</span>
    <h1>Delete Vaccination Record</h1>
    <p>Please confirm before removing this vaccination record.</p>
</section>

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-4">
        <div class="alert alert-danger rounded-4">
            Are you sure you want to delete this vaccination record?
        </div>

        <dl class="row">
            <dt class="col-sm-3">Pet</dt>
            <dd class="col-sm-9">@Model.Pet?.PetName</dd>

            <dt class="col-sm-3">Vaccine</dt>
            <dd class="col-sm-9">@Model.VaccineName</dd>

            <dt class="col-sm-3">Date Given</dt>
            <dd class="col-sm-9">@Model.DateGiven</dd>

            <dt class="col-sm-3">Next Due</dt>
            <dd class="col-sm-9">@Model.NextDueDate</dd>
        </dl>

        <form asp-action="Delete" method="post">
            @Html.AntiForgeryToken()

            <input asp-for="VaccinationId" type="hidden" />

            <button type="submit" class="btn btn-danger rounded-pill px-4">
                Delete
            </button>

            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
                Cancel
            </a>
        </form>
    </div>
</div>