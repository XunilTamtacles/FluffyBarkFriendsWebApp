<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Fluffy BarkFriends</title>

    <link rel="stylesheet"
          href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="~/css/site.css"
          asp-append-version="true" />
</head>

<body>

  
    <header>

        <nav class="navbar navbar-expand-lg app-navbar">

            <div class="container-fluid">

               
                <a class="navbar-brand app-brand"
                   asp-controller="Home"
                   asp-action="Index">

                    <img src="/images/fluffy-logo.png"
                         alt="Fluffy BarkFriends Logo"
                         class="brand-logo" />

                    <span class="brand-text">

                        <span class="brand-name">
                            Fluffy BarkFriends
                        </span>

                        <span class="brand-subtitle">
                            Veterinary Clinic
                        </span>

                    </span>

                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#mainNavbar">

                    <span class="navbar-toggler-icon"></span>

                </button>

               
                <div class="collapse navbar-collapse"
                     id="mainNavbar">

                   
                    <ul class="navbar-nav mx-auto app-nav-links">

                      
                        <li class="nav-item">

                            <a class="nav-link"
                               asp-controller="Home"
                               asp-action="Index">

                                Home

                            </a>

                        </li>

                       
                        <li class="nav-item">

                            <a class="nav-link"
                               asp-controller="Home"
                               asp-action="About">

                                About

                            </a>

                        </li>

                       
                        <li class="nav-item">

                            <a class="nav-link"
                               asp-controller="Home"
                               asp-action="Contact">

                                Contact

                            </a>

                        </li>

                        
                        <li class="nav-item">

                            <a class="nav-link nav-cta"
                               asp-controller="Appointment"
                               asp-action="Book">

                                Book Appointment

                            </a>

                        </li>
                    
                       
                    </ul>

                    <ul class="navbar-nav ms-auto">

                        <li class="nav-item dropdown">

                            <a class="nav-link nav-login-btn dropdown-toggle"
                               href="#"
                               role="button"
                               data-bs-toggle="dropdown">

                                Login

                            </a>

                            <ul class="dropdown-menu dropdown-menu-end login-dropdown">

                                <li>

                                    <a class="dropdown-item"
                                       asp-controller="Account"
                                       asp-action="Login">

                                        Login

                                    </a>

                                </li>

                                <li>

                                    <a class="dropdown-item"
                                       asp-controller="Account"
                                       asp-action="Register">

                                        Register

                                    </a>

                                </li>

                            </ul>

                        </li>

                    </ul>

                </div>

            </div>

        </nav>

    </header>

    <main class="container-fluid px-4 py-4">

        @RenderBody()

    </main>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>