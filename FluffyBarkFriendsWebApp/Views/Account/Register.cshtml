@using FluffyBarkFriendsWebApp.Models.ViewModels
@model RegisterViewModel

@{
    ViewData["Title"] = "Register";
}

<section class="login-wrapper">

    <div class="login-container">

        
        <div class="login-form-section">

            <h1 class="welcome-title">
                Create Account
            </h1>

            <p class="welcome-subtitle">
                Register to access appointments, pet records,
                vaccination tracking, and medical history services.
            </p>

            <form asp-action="Register" method="post">

                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly"
                     class="text-danger mb-3">
                </div>

                <div class="mb-3">

                    <label asp-for="Username"
                           class="form-label">
                    </label>

                    <input asp-for="Username"
                           class="form-control login-input"
                           placeholder="Enter username" />

                    <span asp-validation-for="Username"
                          class="text-danger">
                    </span>

                </div>

                <div class="mb-3">

                    <label asp-for="Email"
                           class="form-label">
                    </label>

                    <input asp-for="Email"
                           class="form-control login-input"
                           placeholder="Enter email address" />

                    <span asp-validation-for="Email"
                          class="text-danger">
                    </span>

                </div>

                <div class="mb-3">

                    <label asp-for="Password"
                           class="form-label">
                    </label>

                    <input asp-for="Password"
                           type="password"
                           class="form-control login-input"
                           placeholder="Enter password" />

                    <span asp-validation-for="Password"
                          class="text-danger">
                    </span>

                </div>

                <div class="mb-4">

                    <label asp-for="ConfirmPassword"
                           class="form-label">
                    </label>

                    <input asp-for="ConfirmPassword"
                           type="password"
                           class="form-control login-input"
                           placeholder="Confirm password" />

                    <span asp-validation-for="ConfirmPassword"
                          class="text-danger">
                    </span>

                </div>

                <button type="submit"
                        class="login-btn">
                    Create Account
                </button>

                <p class="register-link-text">

                    Already have an account?

                    <a asp-action="Login">
                        Login here
                    </a>

                </p>

            </form>

        </div>

        <div class="login-image-section">

            <div class="orange-corner"></div>

            <img src="~/images/fluffy-logo.png"
                 alt="Fluffy BarkFriends Logo"
                 class="login-big-logo" />

        </div>

    </div>

</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}