@model FluffyBarkFriendsWebApp.Models.ViewModels.ForgotPasswordViewModel

@{
    ViewData["Title"] = "Forgot Password";
}

<section class="register-wrapper">
    <div class="register-container">
        <div class="register-form-section">
            <h1 class="welcome-title">Forgot Password</h1>
            <p class="welcome-subtitle">
                Enter your username and create a new password.
            </p>

            <form asp-action="ForgotPassword" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="UserName" class="form-label"></label>
                    <input asp-for="UserName" class="form-control register-input" placeholder="Enter username" />
                    <span asp-validation-for="UserName" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="NewPassword" class="form-label"></label>
                    <input asp-for="NewPassword" class="form-control register-input" placeholder="Enter new password" />
                    <span asp-validation-for="NewPassword" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="form-label"></label>
                    <input asp-for="ConfirmPassword" class="form-control register-input" placeholder="Confirm new password" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>

                <button type="submit" class="register-btn">
                    Reset Password
                </button>

                <p class="login-link-text text-center">
                    Remembered your password?
                    <a asp-action="Login">Login here</a>
                </p>
            </form>
        </div>

        <div class="register-image-section">
            <div class="orange-corner"></div>
            <img src="~/images/fluffy-logo.png" class="register-big-logo" alt="Fluffy BarkFriends" />
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
