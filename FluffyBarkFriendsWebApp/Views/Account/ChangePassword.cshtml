@model FluffyBarkFriendsWebApp.Models.ViewModels.ChangePasswordViewModel

@{
    ViewData["Title"] = "Change Password";
}

<section class="page-panel">
    <span class="eyebrow">Account Settings</span>
    <h1>Change Password</h1>
    <p class="page-description">Update your account password.</p>
</section>

<section class="page-panel">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success rounded-4">
            @TempData["SuccessMessage"]
        </div>
    }

    <form asp-action="ChangePassword" method="post">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label asp-for="CurrentPassword" class="form-label"></label>
            <input asp-for="CurrentPassword" class="form-control register-input" />
            <span asp-validation-for="CurrentPassword" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="NewPassword" class="form-label"></label>
            <input asp-for="NewPassword" class="form-control register-input" />
            <span asp-validation-for="NewPassword" class="text-danger"></span>
        </div>

        <div class="mb-4">
            <label asp-for="ConfirmPassword" class="form-label"></label>
            <input asp-for="ConfirmPassword" class="form-control register-input" />
            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-success rounded-pill px-4">
            Change Password
        </button>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
