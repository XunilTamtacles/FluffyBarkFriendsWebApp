@{
    ViewData["Title"] = "About";
}

<section class="page-panel">
    <span class="eyebrow">About The Clinic</span>
    <h1>Fluffy BarkFriends Veterinary Clinic</h1>
    <p class="lead text-muted">
        A modern veterinary clinic system designed to help pet owners and clinic staff manage appointments,
        pet records, medical history, and vaccination schedules.
    </p>
</section>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body p-4">
                <h3 class="h5 fw-bold">Friendly Pet Care</h3>
                <p class="text-muted mb-0">
                    We provide a warm and organized clinic experience for pets and owners.
                </p>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body p-4">
                <h3 class="h5 fw-bold">Organized Records</h3>
                <p class="text-muted mb-0">
                    The system helps keep pet medical information easy to view and manage.
                </p>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body p-4">
                <h3 class="h5 fw-bold">Online Appointment</h3>
                <p class="text-muted mb-0">
                    Clients can book appointments conveniently using the website.
                </p>
            </div>
        </div>
    </div>
</div>