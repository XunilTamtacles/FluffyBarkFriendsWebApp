@{
    ViewData["Title"] = "About";
}

<div class="container py-4">
    <div class="row align-items-center g-4">
        <div class="col-lg-7">
            <div class="p-4 p-md-5 rounded-4" style="background:#fff7ed;">
                <p class="text-uppercase fw-semibold text-muted mb-2">About The Clinic</p>
                <h1 class="display-6 fw-semibold mb-3">
                    Warm, reliable care for every pet visit.
                </h1>
                <p class="lead text-muted mb-0">
                    Fluffy Bark Friends Veterinary Clinic System helps organize appointments,
                    pet records, medical history, and vaccination care in one clean system.
                </p>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <h2 class="h5">What We Value</h2>
                    <ul class="list-unstyled mb-0 text-muted">
                        <li class="py-2 border-bottom">Comfortable clinic experience</li>
                        <li class="py-2 border-bottom">Trustworthy pet records</li>
                        <li class="py-2">Simple tools for daily care</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mt-4">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4">
                    <h2 class="h5 fw-bold">Our Mission</h2>
                    <p class="text-muted mb-0">
                        To support veterinary clinic staff by providing an organized digital system
                        for managing pet care services and important clinic records.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4">
                    <h2 class="h5 fw-bold">System Features</h2>
                    <ul class="text-muted mb-0">
                        <li>Appointment scheduling</li>
                        <li>Pet profile management</li>
                        <li>Medical history recording</li>
                        <li>Vaccination tracking</li>
                        <li>Dashboard monitoring</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>