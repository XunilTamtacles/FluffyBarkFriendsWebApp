@{
    ViewData["Title"] = "About";
}

<section class="about-hero">

    <div class="about-content">

        <p class="eyebrow">About The Clinic</p>

        <h1>Fluffy BarkFriends Veterinary Clinic</h1>

        <p>
            Fluffy BarkFriends is a modern veterinary clinic system designed to help pet owners and clinic staff manage appointments, pet records, medical history, and vaccination schedules in a simple and organized way.
        </p>

    </div>

    <div class="about-logo-box">
        <img src="~/images/fluffy-logo.png"
             alt="Fluffy BarkFriends Logo" />
    </div>

</section>

<section class="about-card-row">

    <div class="about-card">
        <div class="about-icon">🐾</div>
        <h3>Friendly Pet Care</h3>
        <p>
            We provide a warm and organized clinic experience for pets and their owners.
        </p>
    </div>

    <div class="about-card">
        <div class="about-icon">📋</div>
        <h3>Organized Records</h3>
        <p>
            The system helps keep pet medical information easy to view, update, and manage.
        </p>
    </div>

    <div class="about-card">
        <div class="about-icon">📅</div>
        <h3>Online Appointment</h3>
        <p>
            Clients can request appointments online and wait for clinic confirmation.
        </p>
    </div>

</section>

<section class="about-info-panel">

    <div>
        <p class="eyebrow">Purpose</p>
        <h2>Why this system matters</h2>
        <p>
            The system aims to reduce manual appointment handling, improve record organization,
            and support faster access to important pet health information.
        </p>
    </div>

    <div>
        <p class="eyebrow">Main Features</p>
        <ul>
            <li>Online appointment request</li>
            <li>Pet profile management</li>
            <li>Medical history recording</li>
            <li>Vaccination tracking</li>
            <li>Admin and staff dashboard</li>
        </ul>
    </div>

</section>