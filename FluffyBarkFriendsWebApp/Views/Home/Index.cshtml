@{
    ViewData["Title"] = "Home";
}

<section class="pet-landing">
    <div class="pet-landing-content">
        <span class="pet-kicker">Veterinary Clinic System</span>

        <h1>We care about your pets</h1>

        <p>
            Fluffy BarkFriends helps pet owners book appointments online while the clinic manages pet records,
            medical history, and vaccination schedules.
        </p>

        <div class="pet-actions">
            <a asp-controller="Appointment" asp-action="Book" class="btn pet-primary-btn">
                Book Appointment
            </a>

            <a asp-controller="Account" asp-action="Login" class="btn pet-outline-btn">
                Login
            </a>
        </div>
    </div>

    <div class="pet-landing-visual">
        <div class="pet-photo pet-photo-small">
            <img src="/images/vet-small.jpg" alt="Cat checkup" />
        </div>

        <div class="pet-photo pet-photo-main">
            <img src="/images/vet-main.jpg" alt="Veterinary care" />
        </div>

        <div class="paw-shape">🐾</div>
    </div>
</section>

<section class="home-service-row">
    <div class="home-service-card">
        <div class="service-icon">📅</div>
        <h3>Easy Appointment</h3>
        <p>Clients can request appointments online and wait for clinic confirmation.</p>
    </div>

    <div class="home-service-card">
        <div class="service-icon">🐶</div>
        <h3>Pet Records</h3>
        <p>Manage pet profiles, owner details, and clinic records efficiently.</p>
    </div>

    <div class="home-service-card">
        <div class="service-icon">💉</div>
        <h3>Vaccination Tracking</h3>
        <p>Monitor vaccine schedules and upcoming due dates.</p>
    </div>
</section>