@{
    ViewData["Title"] = "Contact";
}

<div class="container py-4">
    <div class="p-4 p-md-5 rounded-4 mb-4" style="background:#f0fdf4;">
        <p class="text-uppercase fw-semibold text-muted mb-2">Contact</p>
        <h1 class="display-6 fw-semibold mb-3">Reach the clinic team.</h1>
        <p class="lead text-muted mb-0">
            Use this page for clinic contact details, schedule reminders, and support information.
        </p>
    </div>

    <div class="row g-3">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body">
                    <h2 class="h6 text-uppercase text-muted">Phone</h2>
                    <p class="mb-0 fw-semibold">(045) 123-4567</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body">
                    <h2 class="h6 text-uppercase text-muted">Email</h2>
                    <p class="mb-0 fw-semibold">fluffybarkfriends@gmail.com</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body">
                    <h2 class="h6 text-uppercase text-muted">Location</h2>
                    <p class="mb-0 fw-semibold">Angeles City, Pampanga</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mt-3">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body">
                    <h2 class="h6 text-uppercase text-muted">Clinic Hours</h2>
                    <p class="mb-1">Monday - Friday: 8:00 AM - 5:00 PM</p>
                    <p class="mb-0">Saturday: 8:00 AM - 12:00 PM</p>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body">
                    <h2 class="h6 text-uppercase text-muted">Reminder</h2>
                    <p class="mb-0">
                        For appointment concerns, please contact the clinic before your scheduled visit.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>