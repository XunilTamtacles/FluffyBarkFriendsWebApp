@using FluffyBarkFriendsWebApp.Models.ViewModels
@model MedicalHistoryFormsViewModel

@{
    ViewData["Title"] = "Create Medical History Record";
}

<section class="page-panel">
    <span class="eyebrow">Medical History</span>
    <h1>Create Medical Record</h1>
    <p>Add a new medical record for a pet.</p>
</section>

<div class="medical-history-card">
    <form asp-action="Create" method="post">

        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly"
             class="text-danger mb-3">
        </div>

        <partial name="_Form" model="Model" />

        <div class="medical-history-actions">
            <button type="submit"
                    name="submitAction"
                    value="save"
                    class="btn btn-success">
                Save Record
            </button>

            <button type="submit"
                    name="submitAction"
                    value="send"
                    class="btn btn-primary">
                Send Record
            </button>

            <a asp-action="Index"
               class="btn btn-outline-secondary">
                Back
            </a>
        </div>

    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}