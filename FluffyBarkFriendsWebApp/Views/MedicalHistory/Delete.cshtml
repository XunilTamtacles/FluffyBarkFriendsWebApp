@model FluffyBarkFriendsWebApp.Models.Database.MedicalHistory

@{
    ViewData["Title"] = "Medical Record Details";
}

<section class="page-panel">
    <span class="eyebrow">Medical History</span>
    <h1>Medical Record Details</h1>
    <p>Complete information about this pet medical visit.</p>
</section>

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-4">
        <div class="row g-3">
            <div class="col-md-6">
                <div class="clinic-stat rounded-4 p-3">
                    <span class="text-muted small">Pet</span>
                    <h3 class="h5 mb-0">@Model.Pet?.PetName</h3>
                </div>
            </div>

            <div class="col-md-6">
                <div class="clinic-stat rounded-4 p-3">
                    <span class="text-muted small">Visit Date</span>
                    <h3 class="h5 mb-0">@Model.VisitDate</h3>
                </div>
            </div>
        </div>

        <hr />

        <dl class="row">
            <dt class="col-sm-3">Condition</dt>
            <dd class="col-sm-9">@Model.Condition</dd>

            <dt class="col-sm-3">Diagnosis</dt>
            <dd class="col-sm-9">@Model.Diagnosis</dd>

            <dt class="col-sm-3">Treatment</dt>
            <dd class="col-sm-9">@Model.Treatment</dd>

            <dt class="col-sm-3">Medication</dt>
            <dd class="col-sm-9">@Model.Medication</dd>

            <dt class="col-sm-3">Dosage</dt>
            <dd class="col-sm-9">@Model.Dosage</dd>

            <dt class="col-sm-3">Notes</dt>
            <dd class="col-sm-9">@Model.Notes</dd>
        </dl>

        <div class="mt-4 d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.MedicalHistoryId" class="btn btn-success rounded-pill px-4">
                Edit
            </a>

            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
                Back
            </a>
        </div>
    </div>
</div>