@model FluffyBarkFriendsWebApp.Models.ViewModels.AppointmentFormsViewModel

@{
    ViewData["Title"] = "Create Appointment";
}

<section class="page-panel">
    <span class="eyebrow">Appointment Management</span>
    <h1>Create Appointment</h1>
    <p>Add a new appointment schedule for a pet visit.</p>
</section>

<form asp-action="Create" method="post" class="page-panel">
    @Html.AntiForgeryToken()

    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <partial name="_Form" model="Model" />

    <div class="mt-4 d-flex gap-2">
        <button type="submit" class="btn btn-success rounded-pill px-4">
            Save Appointment
        </button>

        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
            Back
        </a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
