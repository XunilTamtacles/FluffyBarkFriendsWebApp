@model FluffyBarkFriendsWebApp.Models.Database.Appointment

@{
    ViewData["Title"] = "Appointment Details";
}

<section class="page-panel">
    <span class="eyebrow">Appointment Information</span>
    <h1>Appointment Details</h1>
    <p>View complete appointment information.</p>
</section>

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-4">
        <dl class="row">
            <dt class="col-sm-3">Pet</dt>
            <dd class="col-sm-9">@Model.Pet?.PetName</dd>

            <dt class="col-sm-3">Date</dt>
            <dd class="col-sm-9">@Model.AppointmentDate</dd>

            <dt class="col-sm-3">Time</dt>
            <dd class="col-sm-9">@Model.AppointmentTime</dd>

            <dt class="col-sm-3">Reason</dt>
            <dd class="col-sm-9">@Model.ReasonVisit</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">@Model.Status</dd>

            <dt class="col-sm-3">Remarks</dt>
            <dd class="col-sm-9">@Model.Remarks</dd>
        </dl>

        <div class="mt-3 d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.AppointmentId" class="btn btn-success rounded-pill px-4">
                Edit
            </a>

            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
                Back
            </a>
        </div>
    </div>
</div>