@model FluffyBarkFriendsWebApp.Models.ViewModels.AppointmentFormsViewModel

<input asp-for="CreatedByUserId" type="hidden" />
<input asp-for="Status" type="hidden" />

<div class="row g-3">
    <div class="col-md-6">
        <label asp-for="PetId" class="form-label">Pet</label>
        <input asp-for="PetId"
               class="form-control"
               placeholder="Enter Pet ID" />
        <span asp-validation-for="PetId" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="AppointmentDate" class="form-label"></label>
        <input asp-for="AppointmentDate"
               type="date"
               class="form-control" />
        <span asp-validation-for="AppointmentDate" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="AppointmentTime" class="form-label"></label>
        <input asp-for="AppointmentTime"
               type="time"
               class="form-control" />
        <span asp-validation-for="AppointmentTime" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="ReasonVisit" class="form-label"></label>
        <input asp-for="ReasonVisit"
               class="form-control"
               placeholder="Check-up, vaccination, grooming..." />
        <span asp-validation-for="ReasonVisit" class="text-danger"></span>
    </div>

    <div class="col-12">
        <label asp-for="Remarks" class="form-label"></label>
        <textarea asp-for="Remarks"
                  class="form-control"
                  rows="4"
                  placeholder="Optional remarks"></textarea>
        <span asp-validation-for="Remarks" class="text-danger"></span>
    </div>
</div>
