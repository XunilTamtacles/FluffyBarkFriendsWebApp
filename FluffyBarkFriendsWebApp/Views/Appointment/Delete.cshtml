@model FluffyBarkFriendsWebApp.Models.Database.Appointment

@{
    ViewData["Title"] = "Delete Appointment";
}

<section class="page-panel">
    <span class="eyebrow">Appointment Management</span>
    <h1>Delete Appointment</h1>
    <p>Confirm if you want to remove this appointment record.</p>
</section>

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-4">
        <p class="text-danger fw-semibold">
            Are you sure you want to delete this appointment?
        </p>

        <dl class="row">
            <dt class="col-sm-3">Pet</dt>
            <dd class="col-sm-9">@Model.Pet?.PetName</dd>

            <dt class="col-sm-3">Date</dt>
            <dd class="col-sm-9">@Model.AppointmentDate</dd>

            <dt class="col-sm-3">Time</dt>
            <dd class="col-sm-9">@Model.AppointmentTime</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">@Model.Status</dd>
        </dl>

        <form asp-action="Delete" method="post">
            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="AppointmentId" />

            <button type="submit" class="btn btn-danger rounded-pill px-4">
                Delete
            </button>

            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
                Cancel
            </a>
        </form>
    </div>
</div>