@using FluffyBarkFriendsWebApp.Models.ViewModels
@model AppointmentFormsViewModel

@{
    ViewData["Title"] = "Book Appointment";
}

<section class="page-panel">
    <span class="eyebrow">Online Booking</span>
    <h1>Book Appointment</h1>
    <p>Schedule your pet visit. Your appointment will be pending until confirmed by the clinic.</p>
</section>

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-4">
        <form asp-action="Book" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <input asp-for="Status" type="hidden" value="Pending" />

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="PetId" class="form-label"></label>
                    <input asp-for="PetId" class="form-control" placeholder="Enter Pet ID" />
                    <span asp-validation-for="PetId" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="CreatedByUserId" class="form-label"></label>
                    <input asp-for="CreatedByUserId" class="form-control" placeholder="Enter User ID" />
                    <span asp-validation-for="CreatedByUserId" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="AppointmentDate" class="form-label"></label>
                    <input asp-for="AppointmentDate" type="date" class="form-control" />
                    <span asp-validation-for="AppointmentDate" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="AppointmentTime" class="form-label"></label>
                    <input asp-for="AppointmentTime" type="time" class="form-control" />
                    <span asp-validation-for="AppointmentTime" class="text-danger"></span>
                </div>

                <div class="col-12">
                    <label asp-for="ReasonVisit" class="form-label"></label>
                    <input asp-for="ReasonVisit" class="form-control" placeholder="Check-up, vaccination, consultation..." />
                    <span asp-validation-for="ReasonVisit" class="text-danger"></span>
                </div>

                <div class="col-12">
                    <label asp-for="Remarks" class="form-label"></label>
                    <textarea asp-for="Remarks" rows="3" class="form-control" placeholder="Optional notes"></textarea>
                    <span asp-validation-for="Remarks" class="text-danger"></span>
                </div>
            </div>

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-success rounded-pill px-4">
                    Submit Appointment
                </button>

                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-success rounded-pill px-4">
                    Back
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}