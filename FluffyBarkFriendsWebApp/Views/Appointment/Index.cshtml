@model List<FluffyBarkFriendsWebApp.Models.Database.Appointment>

@{
    ViewData["Title"] = "Appointments";
}

<section class="page-panel">
    <span class="eyebrow">Clinic Schedule</span>
    <h1>Appointments</h1>
    <p>View and manage pet appointment schedules.</p>
</section>

<div class="mb-3">
    <a asp-action="Create" class="btn btn-success rounded-pill px-4">
        Create Appointment
    </a>
</div>

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-4">
        @if (Model.Any())
        {
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>Pet</th>
                        <th>Date</th>
                        <th>Time</th>
                        <th>Reason</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Pet?.PetName</td>
                            <td>@item.AppointmentDate</td>
                            <td>@item.AppointmentTime</td>
                            <td>@item.ReasonVisit</td>
                            <td>
                                <span class="badge bg-success">@item.Status</span>
                            </td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@item.AppointmentId" class="btn btn-sm btn-outline-success">Details</a>
                                <a asp-action="Edit" asp-route-id="@item.AppointmentId" class="btn btn-sm btn-outline-primary">Edit</a>
                                <a asp-action="Delete" asp-route-id="@item.AppointmentId" class="btn btn-sm btn-outline-danger">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="text-muted mb-0">No appointments found.</p>
        }
    </div>
</div>