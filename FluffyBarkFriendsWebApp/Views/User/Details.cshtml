@model FluffyBarkFriendsWebApp.Models.Database.User

@{
    ViewData["Title"] = "User Details";
}

<section class="page-panel">
    <span class="eyebrow">Admin Management</span>
    <h1>User Details</h1>
    <p>View account information and assigned role.</p>
</section>

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-4">
        <dl class="row">
            <dt class="col-sm-3">Full Name</dt>
            <dd class="col-sm-9">@Model.FullName</dd>

            <dt class="col-sm-3">Username</dt>
            <dd class="col-sm-9">@Model.UserName</dd>

            <dt class="col-sm-3">Role</dt>
            <dd class="col-sm-9">
                <span class="badge rounded-pill bg-success">@Model.Role</span>
            </dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">
                @if (Model.IsActive)
                {
                    <span class="badge rounded-pill bg-primary">Active</span>
                }
                else
                {
                    <span class="badge rounded-pill bg-secondary">Inactive</span>
                }
            </dd>
        </dl>

        <div class="mt-4 d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.UserId" class="btn btn-success rounded-pill px-4">
                Edit
            </a>

            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
                Back
            </a>
        </div>
    </div>
</div>